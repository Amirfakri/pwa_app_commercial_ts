# App
NODE_ENV=development
APP_NAME=PWA_App
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_DATABASE=pwa_app
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session
SESSION_DURATION_DAYS=90

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN=60

# SMS Provider (MeliPayamak)
SMS_PROVIDER=meliPayamak
MELIPAYAMAK_API_KEY=your_api_key
MELI_SMS_USERNAME=your_username
MELIPAYAMAK_FROM=50002710012799

# Admin
ADMIN_PHONE=09123456789
ADMIN_EMAIL=admin@example.com

# ==================== External Price Source ====================
# آدرس API منبع خارجی (برای Polling)
EXTERNAL_PRICE_API_URL=http://localhost:3000/api/all-data

# کلید API برای منبع خارجی
EXTERNAL_PRICE_API_KEY=your-external-api-key-here

# آدرس WebSocket منبع خارجی (برای WebSocket لحظه‌ای)
EXTERNAL_PRICE_WS_URL=ws://localhost:3000

# کلید سرویس دهنده خارجی برای Webhook
EXTERNAL_SOURCE_API_KEY=electro n-price-source-key-2024

# Payment Gateway
PAYMENT_GATEWAY=shetab
PAYMENT_API_KEY=
PAYMENT_CALLBACK_URL=

# WebSocket
WEBSOCKET_PORT=5001
WEBSOCKET_PATH=/ws

# Security
CSRF_ENABLED=false
SECRET_KEY=your_secret_key_for_device_fingerprint
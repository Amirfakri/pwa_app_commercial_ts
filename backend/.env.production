# ==================== Production Configuration ====================
NODE_ENV=production
APP_NAME=PWA_App_Commercial
PORT=3000
HOST=0.0.0.0

# ==================== Database - PostgreSQL (Production) ====================
# از محیط Docker یا Kubernetes دریافت می‌شود
DB_HOST=postgres
DB_PORT=5432
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_DATABASE=${POSTGRES_DB}
DB_SSL=true
DB_SSL_CA_PATH=/app/certs/rds-ca.pem
DB_MAX_CONNECTIONS=50
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# ==================== Redis (Production) ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=pwa:
REDIS_SENTINEL_ENABLED=false

# ==================== JWT Security ====================
# از Secrets Management دریافت شود (Vault/K8s Secrets)
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=RS256

# ==================== Session ====================
SESSION_DURATION_DAYS=30
SESSION_CHECK_INTERVAL=3600000

# ==================== Rate Limiting (Production) ====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_SKIP_SUCCESSFUL=false
RATE_LIMIT_KEY_PREFIX=rate-limit:
RATE_LIMIT_REDIS_ENABLED=true

# ==================== CORS (Production) ====================
CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ==================== Logging & Monitoring ====================
LOG_LEVEL=warn
LOG_FILE_PATH=/var/log/app/app.log
LOG_FORMAT=json
LOG_SLACK_WEBHOOK=${SLACK_WEBHOOK}
SENTRY_DSN=${SENTRY_DSN}

# ==================== External Services ====================
EXTERNAL_PRICE_API_URL=https://api.external.com/v1/prices
EXTERNAL_PRICE_API_KEY=${EXTERNAL_API_KEY}
EXTERNAL_PRICE_WS_URL=wss://stream.external.com/ws
EXTERNAL_SOURCE_API_KEY=${EXTERNAL_SOURCE_KEY}
EXTERNAL_REQUEST_TIMEOUT=5000
EXTERNAL_RETRY_ATTEMPTS=3

# ==================== SMS Provider ====================
SMS_PROVIDER=kavenegar
KAVENEGAR_API_KEY=${KAVENEGAR_API_KEY}
SMS_SENDER=10004346
SMS_OTP_TEMPLATE=otp-template-id
SMS_MAX_RETRY=3
SMS_RETRY_DELAY=1000

# ==================== Payment Gateway ====================
PAYMENT_GATEWAY=zarinpal
ZARINPAL_MERCHANT_ID=${ZARINPAL_MERCHANT_ID}
PAYMENT_CALLBACK_URL=https://api.yourdomain.com/api/payment/callback
PAYMENT_TIMEOUT=30000

# ==================== Admin Settings ====================
ADMIN_PHONE=09123456789
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NOTIFICATION_ENABLED=true

# ==================== Performance & Cache ====================
CACHE_TTL_DEFAULT=300
CACHE_TTL_PRICE=60
CACHE_CHECK_PERIOD=120
ENABLE_QUERY_CACHING=true
QUERY_CACHE_TTL=60

# ==================== Security ====================
CSRF_ENABLED=true
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true
REQUEST_VALIDATION_ENABLED=true
MAX_REQUEST_SIZE=10mb
TRUST_PROXY=true
PROXY_COUNT=1

# ==================== Health Check ====================
HEALTH_CHECK_PATH=/health
READINESS_CHECK_PATH=/ready
LIVENESS_CHECK_PATH=/live
HEALTH_CHECK_TIMEOUT=5000

# ==================== Backup ====================
BACKUP_ENABLED=true
BACKUP_CRON="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=pwa-app-backups
BACKUP_S3_REGION=us-east-1

# ==================== Feature Flags ====================
ENABLE_WEBSOCKET=true
ENABLE_PUSH_NOTIFICATION=true
ENABLE_PRICE_POLLING=true
ENABLE_AUTO_BACKUP=true
ENABLE_MAINTENANCE_MODE=false
{
  "version": 1,
  "name": "pwa-backend",
  "region": "iran",
  "platform": "node",
  "buildCommand": "npm install --no-audit --no-fund --legacy-peer-deps",
  "startCommand": "node backend/dist/server.js",
  "env": {
    "NODE_ENV": "production",
    "NPM_CONFIG_PRODUCTION": "false",
    "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
    "NPM_CONFIG_PACKAGE_LOCK": "false"
  }
}